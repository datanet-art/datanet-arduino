# Arduino sketches do not load .env files directly.
# Keep your real values here while testing, then paste them into a local sketch
# or use your editor/CLI workflow to inject them.

WIFI_SSID=your_wifi_name
WIFI_PASSWORD=your_wifi_password
DATANET_API_KEY=ak_your_api_key_here
DATANET_CHANNEL=project.your_project_id.demo
